# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-32-random-chars-minimum

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=eu-north-1
# Local dev credentials — any non-empty string works with DynamoDB Local
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Point to DynamoDB Local for local dev; comment out to hit real DynamoDB
AWS_ENDPOINT_URL=http://localhost:8000

# S3 bucket name — comment out to store files locally in backend/uploads/
# S3_BUCKET=myapp-uploads

# ── App URLs ─────────────────────────────────────────────────────────────────
# Backend URL that the frontend calls (only needed if frontend and API are on
# different origins; with CloudFront unified domain, remove this and use
# relative URLs in the frontend instead)
# VITE_API_URL=http://localhost:3000

# Base URL for uploaded files
VITE_UPLOADS_URL=http://localhost:3000/uploads

# The frontend origin — used in Express CORS config
FRONTEND_URL=http://localhost:5173

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ── Session cookies ───────────────────────────────────────────────────────────
# Set in production EB env vars; leave unset for local dev
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax

# ── Production reference (not loaded locally — kept for documentation) ────────
# Production URL      : https://<cloudfront-id>.cloudfront.net
# EB environment      : myapp-prod (eu-north-1)
# Amplify app         : <amplify-app-id> (master branch)
# S3 bucket           : myapp-uploads (eu-north-1)
# DynamoDB tables     : myapp-sessions, myapp-users, ...
